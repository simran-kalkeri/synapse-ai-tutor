# ──────────────────────────────────────────────────────────────────────────────
# Synapse AI Tutor — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (choose one) ─────────────────────────────────────────────────
# Option 1: Groq (recommended — fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (local, no API key needed)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Voice Layer ────────────────────────────────────────────────────────────────
# ElevenLabs TTS (optional — gTTS is used as free fallback)
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string-for-production

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse_db
DATABASE_URL_SYNC=postgresql://synapse:synapse@localhost:5432/synapse_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8000

# ── Frontend (dev) ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
