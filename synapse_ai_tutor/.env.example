# ============================================================================
# Synapse AI Tutor — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ============================================================================

# ── LLM Configuration ────────────────────────────────────────────────────────
# Primary: Groq (cloud API, fast inference)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=4096

# Fallback: Ollama (local LLM server, optional)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapse_db
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://synapse:synapse@localhost:5432/synapse_db

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_EXPIRY_HOURS=168

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501/auth/callback

# ── Voice Layer ───────────────────────────────────────────────────────────────
VOICE_MODE=premium
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
GROQ_STT_MODEL=whisper-large-v3

# Optional premium TTS
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Synapse AI Tutor
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=console
DEBUG=false
