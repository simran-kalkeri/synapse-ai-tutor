# Copy this file to secrets.toml and fill in your keys.
# .streamlit/secrets.toml is gitignored — it never gets committed.

[groq]
GROQ_API_KEY = "gsk_..."   # Your Groq API key — get one free at https://console.groq.com

[elevenlabs]
# ELEVENLABS_API_KEY = ""  # Optional premium TTS — leave blank to use free gTTS
